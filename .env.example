# AI Agent Platform - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# TELEGRAM CONFIGURATION
# ============================================
TELEGRAM_BOT_TOKEN=8082924208:AAE3iuMrHb2Dn5EewFDpKOZBNCNhGtiySUI
TELEGRAM_CHANNEL_ID=-1003703092807
TELEGRAM_ADMIN_USERNAME=
TELEGRAM_ALLOWED_USERS=7764037225

# ============================================
# AI MODEL PROVIDERS
# ============================================
# Active provider: fireworks, gemini, ollama, or openai
MODEL_PROVIDER=fireworks

# Default model (provider-specific)
# Fireworks: accounts/fireworks/routers/kimi-k2p5-turbo
MODEL_NAME=accounts/fireworks/routers/kimi-k2p5-turbo

# ============================================
# FIREWORKS AI
# ============================================
FIREWORKS_API_KEY=your_fireworks_api_key_here

# ============================================
# OLLAMA (Cloud + Local)
# ============================================
OLLAMA_API_KEY=a4ab724ab8cc4e10bbf0441874f1582d.o8HnSICvioQnjB7sM9IyLdj5
OLLAMA_HOST=https://api.ollama.com
# Cloud models: minimax-m2:cloud, deepseek-v3.2:cloud, glm-4.6:cloud
# Local models: llama2, codellama, mistral, etc.
OLLAMA_MODEL=minimax-m2:cloud

# ============================================
# GOOGLE GEMINI
# ============================================
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-pro

# ============================================
# OPENAI
# ============================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# ============================================
# MODEL PARAMETERS
# ============================================
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=4096
MODEL_TIMEOUT=60

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_agent_platform
# For Docker:
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ai_agent_platform

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://localhost:6379/0
# For Docker:
# REDIS_URL=redis://redis:6379/0

# ============================================
# API SERVER
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_BASE_URL=http://localhost:8000

# ============================================
# FRONTEND
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================
# MARKET DATA PROVIDERS
# ============================================
# CoinGecko (free tier - no key required for basic usage)
COINGECKO_API_KEY=

# CryptoCompare
CRYPTOCOMPARE_API_KEY=your_cryptocompare_api_key_here

# DexScreener (free - no key required)
DEXSCREENER_API_KEY=

# ============================================
# PAPER TRADING
# ============================================
PAPER_TRADING_INITIAL_BALANCE=10000
PAPER_TRADING_CURRENCY=USD

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# SECURITY
# ============================================
# Generate with: openssl rand -hex 32
SECRET_KEY=your_secret_key_here_change_this_in_production
JWT_SECRET=your_jwt_secret_here_change_this_in_production

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_TELEGRAM=true
ENABLE_WEBSOCKET=true
ENABLE_PAPER_TRADING=true
ENABLE_LIVE_TRADING=false
